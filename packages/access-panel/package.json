{
  "name": "@oksigenia/access-panel",
  "version": "0.3.1",
  "description": "Accessibility panel as a web component. 15 controls (text size, line height, dyslexia font, contrast, colorblind, reading guide, big cursor, pause animations, focus, …) across 8 locales (incl. Guaraní). Zero deps, no tracking.",
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "dyslexia",
    "contrast",
    "colorblind",
    "reading-guide",
    "web-component",
    "vanilla",
    "guarani"
  ],
  "license": "MIT",
  "author": "Oksigenia SL <dev@oksigenia.cc> (https://oksigenia.com)",
  "homepage": "https://github.com/OksigeniaSL/oksigenia-web-libs/tree/main/packages/access-panel",
  "repository": {
    "type": "git",
    "url": "https://github.com/OksigeniaSL/oksigenia-web-libs.git",
    "directory": "packages/access-panel"
  },
  "bugs": "https://github.com/OksigeniaSL/oksigenia-web-libs/issues",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "import": "./dist/web-component.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "happy-dom": "^15.11.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
